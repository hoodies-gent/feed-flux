# FeedFlux Configuration Example

# Google OAuth Credentials
# Download this from Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs
# Save the JSON file as 'credentials.json' in the project root.
# This variable is optional if you use the standard filename 'credentials.json', 
# but good to have for explicit configuration if needed.
GOOGLE_CLIENT_SECRETS_FILE=credentials.json

# LLM Provider (gemini | openai)
LLM_PROVIDER=gemini

# API Keys
# Get your key from: https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# App Settings
LOG_LEVEL=INFO
